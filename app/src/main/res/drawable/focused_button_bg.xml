<?xml version="1.0" encoding="utf-8"?>
<!--
    Button / input field background selector.

    States (priority order):
      focused  → dark green fill + bright green border (2 dp)
      pressed  → solid accent green fill
      default  → dark navy fill + dim border (1 dp)
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Focused (D-pad highlight) -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/button_focused_bg" />
            <stroke android:width="2dp" android:color="@color/focused_border" />
            <corners android:radius="4dp" />
        </shape>
    </item>

    <!-- Pressed / touched -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/button_pressed_bg" />
            <stroke android:width="2dp" android:color="@color/focused_border" />
            <corners android:radius="4dp" />
        </shape>
    </item>

    <!-- Focused + pressed (rare but handled) -->
    <item android:state_focused="true" android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/button_pressed_bg" />
            <stroke android:width="2dp" android:color="@color/focused_border" />
            <corners android:radius="4dp" />
        </shape>
    </item>

    <!-- Default / unfocused -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/button_bg" />
            <stroke android:width="1dp" android:color="@color/normal_border" />
            <corners android:radius="4dp" />
        </shape>
    </item>

</selector>
