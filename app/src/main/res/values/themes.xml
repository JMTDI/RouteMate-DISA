<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ── Base app theme ─────────────────────────────────────────────────── -->
    <style name="Theme.RouteMate" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/accent_green</item>
        <item name="colorPrimaryDark">@color/bg_dark</item>
        <item name="colorAccent">@color/accent_green</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorHint">@color/hint_color</item>
        <!-- Spinner dropdown arrow tint -->
        <item name="colorControlNormal">@color/accent_green</item>
        <item name="colorControlActivated">@color/accent_green</item>
    </style>
    <!-- ── Transparent floating popup (used by PopupActivity) ─────────────── -->
    <style name="Theme.RouteMate.Popup" parent="Theme.AppCompat.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.6</item>
    </style>

</resources>
