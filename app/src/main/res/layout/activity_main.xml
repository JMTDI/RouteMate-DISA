<?xml version="1.0" encoding="utf-8"?>
<!--
    Main settings screen.
    Designed for 320×240 minimum screens, fully D-pad navigable.
    Dark background / green accent colour scheme.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- ── App title ──────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/accent_green"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_subtitle"
            android:textColor="@color/hint_color"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingBottom="16dp" />

        <!-- ── DISA Number ────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_disa_number"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:paddingBottom="4dp" />

        <EditText
            android:id="@+id/et_disa_number"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="phone"
            android:textColor="@color/white"
            android:textColorHint="@color/hint_color"
            android:background="@drawable/focused_button_bg"
            android:padding="10dp"
            android:textSize="18sp"
            android:hint="@string/hint_disa_number"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusDown="@+id/et_pin"
            android:layout_marginBottom="12dp" />

        <!-- ── PIN ───────────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_pin"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:paddingBottom="4dp" />

        <EditText
            android:id="@+id/et_pin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberPassword"
            android:textColor="@color/white"
            android:textColorHint="@color/hint_color"
            android:background="@drawable/focused_button_bg"
            android:padding="10dp"
            android:textSize="18sp"
            android:hint="@string/hint_pin"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusDown="@+id/spinner_initial_pause"
            android:layout_marginBottom="12dp" />

        <!-- ── Initial pause before PIN ──────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_initial_pause"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:paddingBottom="4dp" />

        <Spinner
            android:id="@+id/spinner_initial_pause"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:focusable="true"
            android:background="@drawable/focused_button_bg"
            android:nextFocusDown="@+id/spinner_dest_pause"
            android:layout_marginBottom="12dp" />

        <!-- ── Pause between PIN and destination ──────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_dest_pause"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:paddingBottom="4dp" />

        <Spinner
            android:id="@+id/spinner_dest_pause"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:focusable="true"
            android:background="@drawable/focused_button_bg"
            android:nextFocusDown="@+id/spinner_caller_id_pause"
            android:layout_marginBottom="12dp" />

        <!-- ── Pause before Caller ID entry ──────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_caller_id_pause"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:paddingBottom="4dp" />

        <Spinner
            android:id="@+id/spinner_caller_id_pause"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:focusable="true"
            android:background="@drawable/focused_button_bg"
            android:nextFocusUp="@id/spinner_dest_pause"
            android:nextFocusDown="@+id/btn_add_caller_id"
            android:layout_marginBottom="12dp" />

        <!-- ── Outbound Caller IDs ────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_caller_ids"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:paddingBottom="4dp" />

        <LinearLayout
            android:id="@+id/ll_caller_ids"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/btn_add_caller_id"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/btn_add_caller_id"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:background="@drawable/focused_button_bg"
            android:focusable="true"
            android:nextFocusUp="@id/spinner_caller_id_pause"
            android:nextFocusDown="@+id/btn_accessibility"
            android:layout_marginBottom="20dp" />

        <!-- ── Action buttons ────────────────────────────────────────────── -->
        <Button
            android:id="@+id/btn_accessibility"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/btn_accessibility"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:background="@drawable/focused_button_bg"
            android:focusable="true"
            android:nextFocusUp="@id/btn_add_caller_id"
            android:nextFocusDown="@+id/btn_overlay"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_overlay"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/btn_overlay"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:background="@drawable/focused_button_bg"
            android:focusable="true"
            android:nextFocusUp="@id/btn_accessibility"
            android:nextFocusDown="@+id/btn_save"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/btn_save"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:background="@drawable/focused_button_bg"
            android:focusable="true"
            android:nextFocusUp="@id/btn_overlay"
            android:nextFocusDown="@+id/btn_test"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_test"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/btn_test"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:background="@drawable/focused_button_bg"
            android:focusable="true"
            android:nextFocusUp="@id/btn_save"
            android:layout_marginBottom="18dp" />

        <!-- ── Status panel ──────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/focused_button_bg"
            android:padding="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/status_title"
                android:textColor="@color/accent_green"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <!-- Accessibility service status row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/status_accessibility_label"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_status_accessibility"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_not_enabled"
                    android:textColor="@color/status_error"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Draw over apps status row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/status_overlay_label"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_status_overlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_not_allowed"
                    android:textColor="@color/status_error"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- DISA number status row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/status_disa_label"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_status_disa"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_not_set"
                    android:textColor="@color/status_error"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- bottom padding -->
        <View
            android:layout_width="match_parent"
            android:layout_height="16dp" />

    </LinearLayout>
</ScrollView>
